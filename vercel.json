{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/admin", "dest": "/admin/index.html" },
    { "src": "/admin/", "dest": "/admin/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
